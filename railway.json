{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "echo 'Cron-only service - no continuous process'",
    "cron": [
      {
        "command": "python cloud_run.py",
        "schedule": "0 9,12 * * 1-5"
      }
    ]
  }
}
