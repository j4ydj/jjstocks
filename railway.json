{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python cloud_run.py",
    "cron": [
      {
        "command": "python cloud_run.py",
        "schedule": "0 9,12 * * 1-5"
      }
    ],
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
